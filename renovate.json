{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "assignAutomerge": false,
  "separateMajorMinor": true,
  "packageRules": [
    {
      "description": "Group Kotlin and KSP together — they must stay in sync",
      "matchPackageNames": [
        "org.jetbrains.kotlin:kotlin-gradle-plugin",
        "org.jetbrains.kotlin:kotlin-stdlib",
        "org.jetbrains.kotlin:kotlin-reflect",
        "com.google.devtools.ksp:com.google.devtools.ksp.gradle.plugin",
        "com.google.devtools.ksp:symbol-processing-api"
      ],
      "groupName": "Kotlin + KSP",
      "groupSlug": "kotlin-ksp"
    },
    {
      "description": "Group Android Gradle Plugin with compileSdk/targetSdk if managed via catalog",
      "matchPackageNames": [
        "com.android.tools.build:gradle",
        "com.android.application",
        "com.android.library"
      ],
      "groupName": "Android Gradle Plugin",
      "groupSlug": "agp"
    },
    {
      "description": "Rust toolchain (rust-toolchain.toml)",
      "matchManagers": ["rust"],
      "groupName": "Rust toolchain",
      "groupSlug": "rust-toolchain"
    },
    {
      "description": "Cargo dependencies in wekit-native",
      "matchManagers": ["cargo"],
      "matchFileNames": ["app/src/main/rust/wekit-native/**"],
      "groupName": "Cargo deps (wekit-native)",
      "groupSlug": "cargo-wekit-native",
      "separateMajorMinor": true
    },
    {
      "description": "libs/common/annotation-scanner KSP helper",
      "matchFileNames": ["libs/common/annotation-scanner/**"],
      "groupName": "annotation-scanner deps",
      "groupSlug": "annotation-scanner"
    },
    {
      "description": "libs/common/libxposed-api",
      "matchFileNames": ["libs/common/libxposed-api/**"],
      "groupName": "libxposed-api deps",
      "groupSlug": "libxposed-api"
    },
    {
      "description": "Skip git submodules — nameof-kt is managed manually",
      "matchManagers": ["git-submodules"],
      "matchFileNames": ["libs/external/nameof-kt/**"],
      "enabled": false
    },
    {
      "description": "Auto-merge patch-level bumps for safe, non-breaking deps",
      "matchUpdateTypes": ["patch"],
      "matchPackagePatterns": [
        "^org\\.jetbrains\\.kotlinx:",
        "^com\\.squareup\\.",
        "^io\\.ktor:"
      ],
      "automerge": true,
      "automergeType": "branch"
    }
  ],
  "ignoreDeps": [
    "libs/external/nameof-kt"
  ],
  "gradle": {
    "enabled": true,
    "fileMatch": [
      "(^|/)build\\.gradle\\.kts$",
      "(^|/)settings\\.gradle\\.kts$",
      "(^|/)gradle/libs\\.versions\\.toml$"
    ]
  },
  "cargo": {
    "enabled": true,
    "fileMatch": [
      "app/src/main/rust/wekit-native/Cargo\\.toml$"
    ]
  },
  "git-submodules": {
    "enabled": false
  },
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": ["dependencies", "renovate"]
}
